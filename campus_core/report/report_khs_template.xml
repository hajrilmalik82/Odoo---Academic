<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_khs_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Times New Roman', Times, serif;">

                        <!-- DOCUMENT TITLE -->
                        <div class="text-center mb-4">
                            <h3 style="font-weight: bold; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 2px;">
                                Study Result Card (KHS)
                            </h3>
                            <p style="font-size: 11pt; color: #555; margin-bottom: 0;">
                                Semester: <strong><t t-esc="o.academic_year_id.name or '-'"/></strong>
                            </p>
                            <hr style="border-top: 2px solid #000; margin-top: 10px;"/>
                        </div>

                        <!-- STUDENT INFORMATION -->
                        <table style="width: 100%; font-size: 11pt; margin-bottom: 20px;">
                            <tr>
                                <td style="width: 15%; padding: 3px 0;">Student ID (NIM)</td>
                                <td style="width: 2%;">:</td>
                                <td style="width: 35%;"><strong><t t-esc="o.student_id.nim or '-'"/></strong></td>
                                <td style="width: 15%; padding: 3px 0;">Faculty</td>
                                <td style="width: 2%;">:</td>
                                <td style="width: 31%;"><t t-esc="o.student_id.faculty_id.name or '-'"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 3px 0;">Name</td>
                                <td>:</td>
                                <td><strong><t t-esc="o.student_id.name"/></strong></td>
                                <td style="padding: 3px 0;">Study Program</td>
                                <td>:</td>
                                <td><t t-esc="o.student_id.program_id.name or '-'"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 3px 0;">Academic Year</td>
                                <td>:</td>
                                <td><t t-esc="o.academic_year_id.display_name or '-'"/></td>
                                <td style="padding: 3px 0;">KHS No.</td>
                                <td>:</td>
                                <td><t t-esc="o.name"/></td>
                            </tr>
                        </table>

                        <!-- GRADES TABLE -->
                        <table class="table table-sm table-bordered" style="font-size: 10pt;">
                            <thead>
                                <tr style="background-color: #2c3e50; color: white; text-align: center;">
                                    <th style="width: 5%; padding: 8px;">No</th>
                                    <th style="width: 12%; padding: 8px;">Subject Code</th>
                                    <th style="padding: 8px;">Subject Name</th>
                                    <th style="width: 8%; padding: 8px;">Credits</th>
                                    <th style="width: 10%; padding: 8px;">Numeric Grade</th>
                                    <th style="width: 10%; padding: 8px;">Letter Grade</th>
                                    <th style="width: 10%; padding: 8px;">Weight</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="line_no" t-value="0"/>
                                <t t-foreach="o.line_ids" t-as="line">
                                    <t t-set="line_no" t-value="line_no + 1"/>
                                    <tr>
                                        <td style="text-align: center; padding: 6px;"><t t-esc="line_no"/></td>
                                        <td style="text-align: center; padding: 6px;"><t t-esc="line.subject_id.code or '-'"/></td>
                                        <td style="padding: 6px;"><t t-esc="line.subject_id.name"/></td>
                                        <td style="text-align: center; padding: 6px;"><t t-esc="line.credits"/></td>
                                        <td style="text-align: center; padding: 6px;">
                                            <t t-esc="'%.1f' % line.numeric_grade" t-if="line.numeric_grade"/>
                                            <t t-if="not line.numeric_grade">-</t>
                                        </td>
                                        <td style="text-align: center; padding: 6px; font-weight: bold;">
                                            <t t-esc="line.letter_grade or '-'"/>
                                        </td>
                                        <td style="text-align: center; padding: 6px;">
                                            <t t-esc="'%.2f' % line.grade_points"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background-color: #ecf0f1; font-weight: bold;">
                                    <td colspan="3" style="text-align: right; padding: 8px;">Total</td>
                                    <td style="text-align: center; padding: 8px;"><t t-esc="o.total_credits"/></td>
                                    <td colspan="2" style="text-align: right; padding: 8px;">Semester GPA</td>
                                    <td style="text-align: center; padding: 8px;"><t t-esc="'%.2f' % o.term_gpa"/></td>
                                </tr>
                                <tr style="background-color: #d5dbdb; font-weight: bold;">
                                    <td colspan="5"/>
                                    <td style="text-align: right; padding: 8px;">Cumulative GPA (CGPA)</td>
                                    <td style="text-align: center; padding: 8px;"><t t-esc="'%.2f' % o.student_id.cgpa"/></td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- SIGNATURES -->
                        <div style="margin-top: 40px; font-size: 10pt;">
                            <table style="width: 100%;">
                                <tr>
                                    <td style="width: 50%; text-align: center;">
                                        <p style="margin-bottom: 0;">Approved by,</p>
                                        <p style="margin-bottom: 0;">Head of Study Program</p>
                                        <br/><br/><br/>
                                        <p style="margin-bottom: 0; font-weight: bold; text-decoration: underline;">
                                            <t t-if="o.student_id.program_id.head_id">
                                                <t t-esc="o.student_id.program_id.head_id.name"/>
                                            </t>
                                            <t t-else="">____________________</t>
                                        </p>
                                    </td>
                                    <td style="width: 50%; text-align: center;">
                                        <p style="margin-bottom: 0;">Approved by,</p>
                                        <p style="margin-bottom: 0;">Dean of Faculty</p>
                                        <br/><br/><br/>
                                        <p style="margin-bottom: 0; font-weight: bold; text-decoration: underline;">
                                            <t t-if="o.student_id.faculty_id.dean_id">
                                                <t t-esc="o.student_id.faculty_id.dean_id.name"/>
                                            </t>
                                            <t t-else="">____________________</t>
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
