<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_campus" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.campus</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Academic Info">
                    <group>
                        <group>
                            <field name="is_student"/>
                            <field name="nim" invisible="is_student == False"/>
                            <field name="student_status" invisible="is_student == False"/>
                            <field name="batch_year" invisible="is_student == False"/>
                        </group>
                        <group invisible="is_student == False">
                            <field name="program_id"/>
                            <field name="academic_advisor_id"/>
                            <field name="cgpa" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_partner_tree_student" model="ir.ui.view">
        <field name="name">res.partner.tree.student</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list string="Students" create="0">
                <field name="nim"/>
                <field name="name"/>
                <field name="program_id"/>
                <field name="academic_advisor_id"/>
                <field name="student_status"/>
            </list>
        </field>
    </record>

    <!-- Standalone Student Form View -->
    <record id="view_campus_student_form_standalone" model="ir.ui.view">
        <field name="name">res.partner.form.student.standalone</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form string="Student">
                <header>
                    <field name="student_status" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" default_focus="1" placeholder="Name" required="1"/>
                        </h1>
                        <h2>
                            <field name="nim" placeholder="Student ID (NIM)"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                            <field name="is_student" invisible="1"/>
                            <field name="company_type" invisible="1"/>
                        </group>
                        <group>
                            <field name="faculty_id"/>
                            <field name="program_id"/>
                            <field name="batch_year"/>
                            <field name="academic_advisor_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Contact Details" name="contact_details">
                            <group>
                                <group>
                                    <span class="o_form_label o_td_label" name="address_name">
                                        <b>Address</b>
                                    </span>
                                    <div class="o_address_format">
                                        <field name="street" placeholder="Street..." class="o_address_street"/>
                                        <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                                        <field name="city" placeholder="City" class="o_address_city"/>
                                        <field name="state_id" class="o_address_state" placeholder="State" options="{'no_open': True, 'no_quick_create': True}"/>
                                        <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                                        <field name="country_id" placeholder="Country" class="o_address_country" options="{'no_open': True, 'no_create': True}"/>
                                    </div>
                                </group>
                            </group>
                        </page>
                        <page string="Internal Notes" name="internal_notes">
                            <field name="comment" placeholder="Internal note..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_res_partner_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_student', '=', True)]</field>
        <field name="context">{'default_is_student': True, 'default_company_type': 'person'}</field>
    </record>

    <record id="action_res_partner_student_view_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_partner_tree_student"/>
        <field name="act_window_id" ref="action_res_partner_student"/>
    </record>

    <record id="action_res_partner_student_view_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_campus_student_form_standalone"/>
        <field name="act_window_id" ref="action_res_partner_student"/>
    </record>

</odoo>
