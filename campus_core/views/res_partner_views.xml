<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_campus" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.campus</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Academic Info">
                    <group>
                        <group>
                            <field name="is_student"/>
                            <field name="nim" invisible="is_student == False"/>
                            <field name="student_status" invisible="is_student == False"/>
                            <field name="semester" invisible="is_student == False"/>
                            <field name="batch_year" invisible="is_student == False"/>
                        </group>
                        <group invisible="is_student == False">
                            <field name="program_id"/>
                            <field name="academic_advisor_id"/>
                            <field name="cgpa" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_partner_tree_student" model="ir.ui.view">
        <field name="name">res.partner.tree.student</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list string="Students" create="0">
                <field name="nim"/>
                <field name="name"/>
                <field name="program_id"/>
                <field name="semester"/>
                <field name="academic_advisor_id"/>
                <field name="student_status"/>
            </list>
        </field>
    </record>

    <record id="view_partner_form_student" model="ir.ui.view">
        <field name="name">res.partner.form.student</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="create">0</attribute>
            </xpath>
        </field>
    </record>

    <record id="action_res_partner_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_student', '=', True)]</field>
        <field name="context">{'default_is_student': True, 'default_company_type': 'person'}</field>
    </record>

    <record id="action_res_partner_student_view_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_partner_tree_student"/>
        <field name="act_window_id" ref="action_res_partner_student"/>
    </record>

    <record id="action_res_partner_student_view_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_partner_form_student"/>
        <field name="act_window_id" ref="action_res_partner_student"/>
    </record>

</odoo>
