<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="core_homepage_docs" inherit_id="website.homepage" name="Campus ERP Documentation">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="bg-light pb-5">
                <!-- Header -->
                <section class="bg-white border-bottom pt-5 pb-4 mb-5 shadow-sm">
                    <div class="container text-center">
                        <h1 class="display-5 fw-bold mb-3 text-primary">Dokumentasi Teknis Sistem Informasi Akademik (SIAKAD)</h1>
                        <p class="lead text-muted mx-auto" style="max-width: 900px;">
                            Dokumen ini memuat spesifikasi teknis dan Standard Operating Procedure (SOP) dari Enterprise Resource Planning (ERP) Pendidikan. 
                            Sistem ini dirancang dengan arsitektur modular Odoo, mengimplementasikan automasi Python ORM, validasi bisnis komprehensif, dan sistem keamanan berlapis.
                        </p>
                    </div>
                </section>

                <div class="container py-5">
                    <div class="row">
                        <!-- Navigation Sidebar -->
                        <div class="col-lg-3 mb-4">
                            <div class="sticky-top" style="top: 100px;">
                                <div class="nav flex-column nav-pills shadow-sm border-0 rounded-4 bg-white p-2" id="docs-tab" role="tablist" aria-orientation="vertical">
                                    <button class="nav-link active fw-bold py-3 text-start mb-1" id="tab-core" data-bs-toggle="pill" data-bs-target="#content-core" type="button" role="tab" aria-controls="content-core" aria-selected="true">
                                        <i class="fa fa-cogs me-2"/> Modul Campus Core
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Documentation Content -->
                        <div class="col-lg-9">
                            <div class="tab-content bg-white shadow-sm rounded-4 p-5" id="docs-tabContent">
                                
                                <!-- MODUL CAMPUS CORE -->
                                <div class="tab-pane fade show active" id="content-core" role="tabpanel" aria-labelledby="tab-core">
                                    <section class="mb-5">
                                        <div class="d-flex align-items-center mb-4">
                                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 50px; height: 50px; font-size: 1.25rem;">
                                                <i class="fa fa-cogs"/>
                                            </div>
                                            <h2 class="fw-bold mb-0 text-primary">Modul Campus Core (Manajemen Akademik Inti)</h2>
                                        </div>
                                        <p class="text-muted lead mb-4">
                                            Modul ini adalah jantung dari sistem kampus Anda. Fungsinya mengelola seluruh fondasi data akademik, mulai dari manajemen kurikulum, penyusunan jadwal kuliah, pengisian Kartu Rencana Studi (KRS), hingga pencetakan transkrip nilai (KHS). Dirancang agar proses akademik berjalan lancar, otomatis, dan minim kesalahan administrasi.
                                        </p>
                                        
                                        <!-- HIGHLIGHT FITUR -->
                                        <div class="row mb-5">
                                            <div class="col-md-4">
                                                <div class="card border-0 shadow-sm h-100 rounded-4">
                                                    <div class="card-body">
                                                        <h5 class="fw-bold text-dark"><i class="fa fa-shield text-danger me-2"/>Smart Constraints (Cerdas)</h5>
                                                        <p class="text-muted small mb-0">Sistem otomatis memblokir mahasiswa yang mengambil SKS melebihi batas IPK-nya, serta mencegah pendaftaran jika kapasitas ruangan kelas sudah penuh. Tidak ada lagi kelonggaran administrasi manual.</p>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="card border-0 shadow-sm h-100 rounded-4">
                                                    <div class="card-body">
                                                        <h5 class="fw-bold text-dark"><i class="fa fa-calendar-check-o text-primary me-2"/>Dynamic Scheduling</h5>
                                                        <p class="text-muted small mb-0">Sistem mendeteksi bentrok jadwal kuliah (Time Overlap) secara *real-time* saat mahasiswa menyusun KRS, memastikan mahasiswa tidak memilih dua kelas di waktu yang bersamaan.</p>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="card border-0 shadow-sm h-100 rounded-4">
                                                    <div class="card-body">
                                                        <h5 class="fw-bold text-dark"><i class="fa fa-calculator text-success me-2"/>Automasi Transkrip KHS</h5>
                                                        <p class="text-muted small mb-0">Dosen cukup memasukkan nilai akhir angka (misal: 85). Sistem otomatis mengonversi ke huruf (A), mengkalikan poin (4.0) dengan SKS, dan menghitung IPK (Indeks Prestasi) mahasiswa tanpa hitungan manual.</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <h4 class="fw-bold border-bottom pb-2 mb-4">Alur Kerja (Workflow) Kegiatan Akademik</h4>

                                        <!-- TAHAP 1 -->
                                        <div class="mb-4 ps-4 border-start border-4 border-secondary position-relative">
                                            <span class="badge bg-secondary position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">1</span>
                                            <h5 class="fw-bold text-dark pt-1">Persiapan Master Data (Pre-requisite)</h5>
                                            <p class="mb-2"><strong>Aktor:</strong> Administrator Akademik (Biro Akademik)</p>
                                            <p class="mb-2">Sebelum semester dimulai, Admin wajib mempersiapkan fondasi kurikulum:</p>
                                            <ul class="text-muted mb-2">
                                                <li>Membuat <strong>Tahun Akademik</strong> aktif (Contoh: 2026/2027 Ganjil).</li>
                                                <li>Memasukkan daftar <strong>Mata Kuliah</strong> dan menetapkan bobot SKS.</li>
                                                <li>Mendaftarkan <strong>Ruangan Kelas</strong> beserta <em>Kapasitas Maksimal</em> (Max Capacity).</li>
                                            </ul>
                                        </div>

                                        <!-- TAHAP 2 (BARU) -->
                                        <div class="mb-4 ps-4 border-start border-4 border-info position-relative">
                                            <span class="badge bg-info position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">2</span>
                                            <h5 class="fw-bold text-dark pt-1">Penjadwalan &amp; Pembukaan Kelas</h5>
                                            <p class="mb-2"><strong>Aktor:</strong> Administrator Akademik (Biro Akademik)</p>
                                            <p class="mb-2">Admin membuat <strong>Kelas (Class)</strong> untuk mata kuliah yang akan diajarkan, kemudian menyusun <strong>Jadwal Kelas (Class Schedule)</strong>.</p>
                                            <div class="bg-light p-3 rounded mb-2">
                                                <i class="fa fa-calendar text-dark me-2"/> <strong>Sistem Jadwal:</strong> Jadwal menentukan Hari, Jam Mulai, Jam Selesai, Ruangan, dan Dosen Pengampu. Anda dapat membuat beberapa jadwal untuk satu kelas (misalnya teori dan lab).
                                            </div>
                                            <div class="bg-light p-3 rounded">
                                                <i class="fa fa-users text-info me-2"/> <strong>Kapasitas Otomatis:</strong> Odoo secara otomatis menghitung jumlah kapasitas maksimal kelas berdasarkan daya tampung Ruangan yang dipilih pada jadwal tersebut!
                                            </div>
                                        </div>

                                        <!-- TAHAP 3 -->
                                        <div class="mb-4 ps-4 border-start border-4 border-primary position-relative">
                                            <span class="badge bg-primary position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">3</span>
                                            <h5 class="fw-bold text-dark pt-1">Pengisian Kartu Rencana Studi (KRS)</h5>
                                            <p class="mb-2"><strong>Aktor:</strong> Mahasiswa / Admin Akademik</p>
                                            <p class="mb-2">Mahasiswa menyusun rencana studi untuk semester berjalan. Pengisian bisa dilakukan mandiri via Portal atau dibantu Admin.</p>
                                            <div class="bg-light p-3 rounded mb-2">
                                                <i class="fa fa-exclamation-triangle text-danger me-2"/> <strong>Validasi Ketat:</strong> Sistem <strong>menolak</strong> pengajuan KRS jika: (1) SKS melebihi jatah IPK, (2) Jadwal kelas berbenturan, (3) Kuota kelas sudah penuh, atau (4) Mahasiswa belum lulus mata kuliah prasyarat.
                                            </div>
                                            <div class="bg-light p-3 rounded">
                                                <i class="fa fa-check-circle text-success me-2"/> <strong>Aksi:</strong> Mahasiswa menekan tombol <strong>Submit</strong> untuk mengirim KRS ke Dosen Pembimbing (PA).
                                            </div>
                                        </div>

                                        <!-- TAHAP 4 -->
                                        <div class="mb-4 ps-4 border-start border-4 border-warning position-relative">
                                            <span class="badge bg-warning text-dark position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">4</span>
                                            <h5 class="fw-bold text-dark pt-1">Persetujuan Dosen Wali (Approval KRS)</h5>
                                            <p class="mb-2"><strong>Aktor:</strong> Dosen Pembimbing Akademik (PA)</p>
                                            <p class="mb-2">Dosen PA melakukan peninjauan terhadap mata kuliah yang diajukan oleh mahasiswa bimbingannya.</p>
                                            <div class="bg-light p-3 rounded mb-2">
                                                <i class="fa fa-lock text-dark me-2"/> <strong>Keamanan (Row-Level Security):</strong> Dosen A <strong>tidak akan bisa</strong> menyetujui atau melihat KRS dari mahasiswa bimbingan Dosen B. Hak akses dibatasi secara absolut.
                                            </div>
                                            <div class="bg-light p-3 rounded">
                                                <i class="fa fa-check-circle text-success me-2"/> <strong>Aksi:</strong> Dosen menekan <strong>Approve</strong>. KRS terkunci dan mahasiswa resmi terdaftar di kelas.
                                            </div>
                                        </div>

                                        <!-- TAHAP 5 -->
                                        <div class="mb-4 ps-4 border-start border-4 border-success position-relative">
                                            <span class="badge bg-success position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">5</span>
                                            <h5 class="fw-bold text-dark pt-1">Penerbitan KHS &amp; Penilaian (Akhir Semester)</h5>
                                            <p class="mb-2"><strong>Aktor:</strong> Dosen Pengampu / Admin Akademik</p>
                                            <p class="mb-2">Di akhir masa perkuliahan, nilai harus diterbitkan dalam bentuk Kartu Hasil Studi (KHS).</p>
                                            <div class="bg-light p-3 rounded mb-2">
                                                <i class="fa fa-magic text-dark me-2"/> <strong>Automasi Penciptaan:</strong> Admin tidak perlu membuat KHS dari nol. Cukup tekan tombol <strong>Lock &amp; Generate KHS</strong> pada KRS mahasiswa, sistem otomatis membuatkan salinan persis di modul KHS!
                                            </div>
                                            <div class="bg-light p-3 rounded">
                                                <i class="fa fa-calculator text-success me-2"/> <strong>Aksi:</strong> Dosen menginput nilai akhir (misal: 80). Sistem seketika (real-time) mengalkulasi Nilai Mutu dan IPK (Indeks Prestasi Kumulatif) mahasiswa bersangkutan.
                                            </div>
                                        </div>

                                        <!-- TAHAP 6 (BARU) -->
                                        <div class="mb-4 ps-4 border-start border-4 border-info position-relative">
                                            <span class="badge bg-info position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">6</span>
                                            <h5 class="fw-bold text-dark pt-1">Mass KRS Generator &amp; Course Packages (Fitur Otomatisasi Lanjut)</h5>
                                            <p class="mb-2"><strong>Aktor:</strong> Admin Akademik</p>
                                            <p class="mb-2">Tidak perlu lagi menyusun KRS satu per satu! Kini Anda bisa menggunakan alat <em>Wizard</em> pintar.</p>
                                            <div class="bg-light p-3 rounded mb-2">
                                                <i class="fa fa-cubes text-dark me-2"/> <strong>Course Packages:</strong> Kumpulkan mata kuliah wajib untuk setiap Program Studi ke dalam satu Paket (Package) per Tahun Akademik.
                                            </div>
                                            <div class="bg-light p-3 rounded">
                                                <i class="fa fa-flash text-info me-2"/> <strong>Aksi (Generate KRS):</strong> Tekan tombol "Generate KRS" pada Paket, lalu sistem akan memfilter mahasiswa prodi tersebut yang belum membuat KRS. Centang puluhan nama mahasiswa, dan <em>Draft KRS</em> massal (berikut baris-baris mata kuliahnya) akan terbit dalam sekejap mata!
                                            </div>
                                        </div>

                                        <!-- TAHAP 7 (BARU) -->
                                        <div class="mb-4 ps-4 border-start border-4 border-primary position-relative">
                                            <span class="badge bg-primary position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">7</span>
                                            <h5 class="fw-bold text-dark pt-1">Mass Schedule Assignment (Penjadwalan Massal)</h5>
                                            <p class="mb-2"><strong>Aktor:</strong> Admin Akademik</p>
                                            <p class="mb-2">Setelah KRS di-generate, Admin tidak perlu lagi mengatur jadwal mahasiswa satu per satu secara manual!</p>
                                            <div class="bg-light p-3 rounded">
                                                <i class="fa fa-magic text-primary me-2"/> <strong>Aksi (Assign Schedule):</strong> Buka form Kelas, klik tab <strong>Students</strong>, lalu tekan tombol <strong>Assign Schedule (Massive)</strong>. Sistem akan mencari semua mahasiswa yang mengambil kelas ini tetapi belum memiliki jadwal, dan Anda bisa memasukkan mereka ke dalam sebuah jadwal sekaligus dalam satu tarikan napas!
                                            </div>
                                        </div>
                                        <!-- TAHAP 8 (BARU) -->
                                        <div class="mb-4 ps-4 border-start border-4 border-danger position-relative">
                                            <span class="badge bg-danger position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">8</span>
                                            <h5 class="fw-bold text-dark pt-1">Perpindahan Status Massal via Menu Actions</h5>
                                            <p class="mb-2"><strong>Aktor:</strong> Admin Akademik / Dosen PA</p>
                                            <p class="mb-2">Tidak perlu membuka satu per satu dokumen KRS untuk mengubah statusnya! Cukup gunakan fitur <em>Actions</em> di tampilan daftar.</p>
                                            <div class="bg-light p-3 rounded mb-2">
                                                <i class="fa fa-list-ul text-dark me-2"/> <strong>Cara Penggunaan:</strong> Buka menu <strong>Study Plan (KRS)</strong> → Centang satu atau beberapa baris KRS yang ingin diproses → Klik tombol <strong>"⚙️ Actions"</strong> di bagian atas tabel.
                                            </div>
                                            <div class="bg-light p-3 rounded mb-2">
                                                <i class="fa fa-bolt text-danger me-2"/> <strong>Opsi yang tersedia di menu Actions:</strong>
                                                <ul class="mt-2 mb-0 text-muted">
                                                    <li><strong>Mass Submit</strong> — Kirim semua KRS berstatus <em>Draft</em> yang dicentang sekaligus ke Dosen PA.</li>
                                                    <li><strong>Mass Approve</strong> — Setujui semua KRS berstatus <em>Submitted</em> yang dicentang sekaligus (khusus Dosen PA / Admin).</li>
                                                    <li><strong>Mass Lock</strong> — Kunci semua KRS berstatus <em>Approved</em> dan otomatis buatkan KHS-nya (khusus Admin).</li>
                                                    <li><strong>Mass Reject</strong> — Tolak semua KRS berstatus <em>Submitted</em> yang dicentang sekaligus.</li>
                                                    <li><strong>Mass Unlock</strong> — Buka kembali KRS yang sudah terkunci ke status <em>Approved</em> jika diperlukan koreksi (khusus Admin).</li>
                                                </ul>
                                            </div>
                                            <div class="bg-light p-3 rounded">
                                                <i class="fa fa-info-circle text-info me-2"/> <strong>Catatan Cerdas:</strong> Sistem akan secara otomatis melewati (skip) baris yang statusnya tidak sesuai. Misalnya, jika Anda mencentang 10 KRS lalu memilih <em>Mass Approve</em>, hanya KRS yang berstatus <em>Submitted</em> yang akan diproses; KRS berstatus Draft tidak akan tersentuh.
                                            </div>
                                        </div>

                                        <!-- SECTION: PERAN & HAK AKSES -->
                                        <h4 class="fw-bold border-bottom pb-2 mb-4 mt-5">Peran Pengguna &amp; Hak Akses (Roles &amp; Permissions)</h4>
                                        <p class="text-muted mb-4">Sistem ini dirancang dengan hierarki keamanan berlapis. Setiap pengguna hanya dapat melihat dan melakukan tindakan yang sesuai dengan perannya.</p>

                                        <div class="table-responsive">
                                            <table class="table table-bordered table-hover align-middle">
                                                <thead class="table-dark">
                                                    <tr>
                                                        <th>Tindakan</th>
                                                        <th class="text-center">Mahasiswa (Portal)</th>
                                                        <th class="text-center">Dosen PA</th>
                                                        <th class="text-center">Admin Akademik</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr>
                                                        <td>Buat &amp; Edit KRS (saat periode buka)</td>
                                                        <td class="text-center text-success fw-bold">✓</td>
                                                        <td class="text-center text-muted">—</td>
                                                        <td class="text-center text-success fw-bold">✓ (kapan saja)</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Submit KRS</td>
                                                        <td class="text-center text-success fw-bold">✓</td>
                                                        <td class="text-center text-muted">—</td>
                                                        <td class="text-center text-success fw-bold">✓</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Approve / Reject KRS</td>
                                                        <td class="text-center text-danger">✗</td>
                                                        <td class="text-center text-success fw-bold">✓ (mahasiswa bimbingannya saja)</td>
                                                        <td class="text-center text-success fw-bold">✓ (semua)</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Lock KRS &amp; Generate KHS</td>
                                                        <td class="text-center text-danger">✗</td>
                                                        <td class="text-center text-danger">✗</td>
                                                        <td class="text-center text-success fw-bold">✓</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Input Nilai (KHS)</td>
                                                        <td class="text-center text-danger">✗</td>
                                                        <td class="text-center text-success fw-bold">✓</td>
                                                        <td class="text-center text-success fw-bold">✓</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Kelola Master Data (Prodi, Ruangan, dll)</td>
                                                        <td class="text-center text-danger">✗</td>
                                                        <td class="text-center text-danger">✗</td>
                                                        <td class="text-center text-success fw-bold">✓</td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>

                                        <!-- SECTION: PERIODE KRS -->
                                        <h4 class="fw-bold border-bottom pb-2 mb-4 mt-5">Konfigurasi Periode KRS</h4>
                                        <p class="text-muted mb-3">Sistem mendukung pembatasan waktu pengisian KRS agar mahasiswa hanya bisa mengisi pada periode yang sudah ditentukan.</p>
                                        <div class="bg-light p-3 rounded mb-2">
                                            <i class="fa fa-calendar-check-o text-primary me-2"/> <strong>Cara Setting:</strong> Buka menu <strong>Configuration → Academic Years</strong> → Pilih Tahun Akademik yang aktif → Isi kolom <strong>KRS Start Date</strong> dan <strong>KRS End Date</strong>.
                                        </div>
                                        <div class="bg-light p-3 rounded">
                                            <i class="fa fa-info-circle text-info me-2"/> <strong>Catatan:</strong> Pembatasan periode ini <strong>hanya berlaku untuk Mahasiswa</strong> (pengguna Portal). Admin Akademik dapat membuat atau mengedit KRS kapan saja tanpa terikat periode, sehingga dapat membantu mahasiswa yang berhalangan mengisi sendiri.
                                        </div>
                                    </section>
                                </div>
                                
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
