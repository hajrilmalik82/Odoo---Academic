<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="core_homepage_docs" inherit_id="website.homepage" name="Campus ERP Documentation">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="bg-light pb-5">
                <!-- Header -->
                <section class="bg-white border-bottom pt-5 pb-4 mb-5 shadow-sm">
                    <div class="container text-center">
                        <h1 class="display-5 fw-bold mb-3 text-primary">Academic Information System (SIAKAD) Technical Documentation</h1>
                        <p class="lead text-muted mx-auto" style="max-width: 900px;">
                            This document contains the technical specifications and Standard Operating Procedure (SOP) of the Educational Enterprise Resource Planning (ERP).
                            The system is designed with Odoo's modular architecture, implementing Python ORM automation, comprehensive business validation, and layered security systems.
                        </p>
                    </div>
                </section>

                <div class="container py-5">
                    <div class="row">
                        <!-- Navigation Sidebar -->
                        <div class="col-lg-3 mb-4">
                            <div class="sticky-top" style="top: 100px;">
                                <div class="nav flex-column nav-pills shadow-sm border-0 rounded-4 bg-white p-2" id="docs-tab" role="tablist" aria-orientation="vertical">
                                    <button class="nav-link active fw-bold py-3 text-start mb-1" id="tab-core" data-bs-toggle="pill" data-bs-target="#content-core" type="button" role="tab" aria-controls="content-core" aria-selected="true">
                                        <i class="fa fa-cogs me-2"/> Campus Core Module
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Documentation Content -->
                        <div class="col-lg-9">
                            <div class="tab-content bg-white shadow-sm rounded-4 p-5" id="docs-tabContent">
                                
                                <!-- MODUL CAMPUS CORE -->
                                <div class="tab-pane fade show active" id="content-core" role="tabpanel" aria-labelledby="tab-core">
                                    <section class="mb-5">
                                        <div class="d-flex align-items-center mb-4">
                                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 50px; height: 50px; font-size: 1.25rem;">
                                                <i class="fa fa-cogs"/>
                                            </div>
                                            <h2 class="fw-bold mb-0 text-primary">Campus Core Module (Core Academic Management)</h2>
                                        </div>
                                        <p class="text-muted lead mb-4">
                                            This module is the heart of your campus system. It manages all academic foundation data, starting from curriculum management, course scheduling, Study Plan (KRS) entry, to grade transcript (KHS) printing. Designed to keep academic processes running smoothly, automatically, and with minimal administrative errors.
                                        </p>
                                        
                                        <!-- HIGHLIGHT FITUR -->
                                        <div class="row mb-5">
                                            <div class="col-md-3">
                                                <div class="card border-0 shadow-sm h-100 rounded-4">
                                                    <div class="card-body">
                                                        <h5 class="fw-bold text-dark"><i class="fa fa-shield text-danger me-2"/>Smart Constraints</h5>
                                                        <p class="text-muted small mb-0">The system automatically blocks students from taking credits (SKS) exceeding their GPA limit, and prevents registration if the class capacity is full. No more manual administrative leniency.</p>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="card border-0 shadow-sm h-100 rounded-4">
                                                    <div class="card-body">
                                                        <h5 class="fw-bold text-dark"><i class="fa fa-calendar-check-o text-primary me-2"/>Dynamic Scheduling</h5>
                                                        <p class="text-muted small mb-0">The system detects class schedule conflict (Time Overlap) in real-time when students compile their KRS, ensuring students do not choose two classes at the same time.</p>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="card border-0 shadow-sm h-100 rounded-4">
                                                    <div class="card-body">
                                                        <h5 class="fw-bold text-dark"><i class="fa fa-calculator text-success me-2"/>KHS Transcript Automation</h5>
                                                        <p class="text-muted small mb-0">Lecturers only need to enter the final numeric score (e.g. 85). The system automatically converts it to a letter grade (A), multiplies the points (4.0) by credits (SKS), and calculates the student's GPA without manual calculation.</p>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="card border-0 shadow-sm h-100 rounded-4">
                                                    <div class="card-body">
                                                        <h5 class="fw-bold text-dark"><i class="fa fa-user-md text-info me-2"/>Smart Advisor Assignment</h5>
                                                        <p class="text-muted small mb-0">When assigning an Academic Advisor, the system automatically filters the list to only show active Lecturers within the same Study Program as the student. No more misassigned roles.</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <h4 class="fw-bold border-bottom pb-2 mb-4">Academic Workflow</h4>

                                        <!-- TAHAP 1 -->
                                        <div class="mb-4 ps-4 border-start border-4 border-secondary position-relative">
                                            <span class="badge bg-secondary position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">1</span>
                                            <h5 class="fw-bold text-dark pt-1">Master Data Preparation (Prerequisites)</h5>
                                            <p class="mb-2"><strong>Actor:</strong> Academic Administrator (Academic Office)</p>
                                            <p class="mb-2">Before the semester starts, the Admin must prepare the curriculum foundation:</p>
                                            <ul class="text-muted mb-2">
                                                <li>Create active <strong>Academic Year</strong> (Example: 2026/2027 Odd).</li>
                                                <li>Enter the list of <strong>Subjects</strong> and assign credits (SKS) weights.</li>
                                                <li>Register <strong>Classrooms</strong> along with <em>Maximum Capacity</em> (Max Capacity).</li>
                                            </ul>
                                        </div>

                                        <!-- TAHAP 2 -->
                                        <div class="mb-4 ps-4 border-start border-4 border-info position-relative">
                                            <span class="badge bg-info position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">2</span>
                                            <h5 class="fw-bold text-dark pt-1">Scheduling &amp; Opening Classes</h5>
                                            <p class="mb-2"><strong>Actor:</strong> Academic Administrator (Academic Office)</p>
                                            <p class="mb-2">Admin creates a <strong>Class (Class)</strong> for the subject to be taught, then arranges the <strong>Class Schedule (Class Schedule)</strong>.</p>
                                            <div class="bg-light p-3 rounded mb-2">
                                                <i class="fa fa-calendar text-dark me-2"/> <strong>Scheduling System:</strong> Schedule determines Day, Start Time, End Time, Room, and Lecturer. You can create multiple schedules for one class (e.g., theory and lab).
                                            </div>
                                            <div class="bg-light p-3 rounded">
                                                <i class="fa fa-users text-info me-2"/> <strong>Automatic Capacity:</strong> Odoo automatically calculates the class maximum capacity based on the capacity of the selected Room in the schedule!
                                            </div>
                                        </div>

                                        <!-- TAHAP 3 -->
                                        <div class="mb-4 ps-4 border-start border-4 border-primary position-relative">
                                            <span class="badge bg-primary position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">3</span>
                                            <h5 class="fw-bold text-dark pt-1">Study Plan (KRS) Filling</h5>
                                            <p class="mb-2"><strong>Actor:</strong> Student / Academic Admin</p>
                                            <p class="mb-2">Students compile their study plan for the current semester. It can be filled independently via the Portal or assisted by the Admin.</p>
                                            <div class="bg-light p-3 rounded mb-2">
                                                <i class="fa fa-exclamation-triangle text-danger me-2"/> <strong>Strict Validation:</strong> The system <strong>rejects</strong> KRS submissions if: (1) SKS exceeds the GPA limit, (2) Schedule conflicts, (3) Class quota is full, or (4) Student has not passed the prerequisite subjects.
                                            </div>
                                            <div class="bg-light p-3 rounded">
                                                <i class="fa fa-check-circle text-success me-2"/> <strong>Action:</strong> Student clicks <strong>Submit</strong> to send KRS to the Academic Advisor (PA).
                                            </div>
                                        </div>

                                        <!-- TAHAP 4 -->
                                        <div class="mb-4 ps-4 border-start border-4 border-warning position-relative">
                                            <span class="badge bg-warning text-dark position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">4</span>
                                            <h5 class="fw-bold text-dark pt-1">Academic Advisor Approval (KRS Approval)</h5>
                                            <p class="mb-2"><strong>Actor:</strong> Academic Advisor (PA)</p>
                                            <p class="mb-2">The Advisor reviews the subjects submitted by their advised students.</p>
                                            <div class="bg-light p-3 rounded mb-2">
                                                <i class="fa fa-lock text-dark me-2"/> <strong>Security (Row-Level Security):</strong> Advisor A <strong>cannot</strong> approve or view KRS from Advisor B's students. Access rights are absolutely restricted.
                                            </div>
                                            <div class="bg-light p-3 rounded">
                                                <i class="fa fa-check-circle text-success me-2"/> <strong>Action:</strong> Advisor clicks <strong>Approve</strong>. KRS is locked and the student is officially registered in the class.
                                            </div>
                                        </div>

                                        <!-- TAHAP 5 -->
                                        <div class="mb-4 ps-4 border-start border-4 border-success position-relative">
                                            <span class="badge bg-success position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">5</span>
                                            <h5 class="fw-bold text-dark pt-1">KHS Issuance &amp; Grading (End of Semester)</h5>
                                            <p class="mb-2"><strong>Actor:</strong> Course Lecturer / Academic Admin</p>
                                            <p class="mb-2">At the end of the lecture period, grades must be issued in the form of a Study Result Card (KHS).</p>
                                            <div class="bg-light p-3 rounded mb-2">
                                                <i class="fa fa-magic text-dark me-2"/> <strong>Automatic Creation:</strong> Admin does not need to create KHS from scratch. Simply click <strong>Lock &amp; Generate KHS</strong> on the student's KRS, and the system automatically creates an exact copy in the KHS module!
                                            </div>
                                            <div class="bg-light p-3 rounded">
                                                <i class="fa fa-calculator text-success me-2"/> <strong>Action:</strong> Lecturer inputs final grade (e.g. 80). The system instantly calculates the grade points and GPA (Cumulative Grade Point Average) of the student.
                                            </div>
                                        </div>

                                        <!-- TAHAP 6 -->
                                        <div class="mb-4 ps-4 border-start border-4 border-info position-relative">
                                            <span class="badge bg-info position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">6</span>
                                            <h5 class="fw-bold text-dark pt-1">Mass KRS Generator &amp; Course Packages (Advanced Automation)</h5>
                                            <p class="mb-2"><strong>Actor:</strong> Academic Admin</p>
                                            <p class="mb-2">No need to compile KRS one by one anymore! Now you can use our smart <em>Wizard</em>.</p>
                                            <div class="bg-light p-3 rounded mb-2">
                                                <i class="fa fa-cubes text-dark me-2"/> <strong>Course Packages:</strong> Collect mandatory subjects for each Study Program into a Package per Academic Year.
                                            </div>
                                            <div class="bg-light p-3 rounded">
                                                <i class="fa fa-flash text-info me-2"/> <strong>Action (Generate KRS):</strong> Click "Generate KRS" on the Package, and the system will filter students of that program who have not created KRS. Check dozens of student names, and mass <em>Draft KRS</em> (with their subject lines) will be issued in the blink of an eye!
                                            </div>
                                        </div>

                                        <!-- TAHAP 7 -->
                                        <div class="mb-4 ps-4 border-start border-4 border-primary position-relative">
                                            <span class="badge bg-primary position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">7</span>
                                            <h5 class="fw-bold text-dark pt-1">Mass Schedule Assignment</h5>
                                            <p class="mb-2"><strong>Actor:</strong> Academic Admin</p>
                                            <p class="mb-2">After KRS is generated, the Admin no need to set student schedules one by one manually!</p>
                                            <div class="bg-light p-3 rounded">
                                                <i class="fa fa-magic text-primary me-2"/> <strong>Action (Assign Schedule):</strong> Open Class form, click <strong>Students</strong> tab, then click <strong>Assign Schedule (Massive)</strong>. The system will search for all students taking this class but have no schedule, and you can assign them to a schedule at once!
                                            </div>
                                        </div>
                                        
                                        <!-- TAHAP 8 -->
                                        <div class="mb-4 ps-4 border-start border-4 border-danger position-relative">
                                            <span class="badge bg-danger position-absolute" style="left: -15px; top: 0px; font-size: 1rem;">8</span>
                                            <h5 class="fw-bold text-dark pt-1">Mass Status Transitions via Actions Menu</h5>
                                            <p class="mb-2"><strong>Actor:</strong> Academic Admin / Academic Advisor</p>
                                            <p class="mb-2">No need to open KRS documents one by one to change status! Simply use the <em>Actions</em> feature in list view.</p>
                                            <div class="bg-light p-3 rounded mb-2">
                                                <i class="fa fa-list-ul text-dark me-2"/> <strong>How to Use:</strong> Open <strong>Study Plan (KRS)</strong> menu → Check one or more KRS lines to process → Click <strong>"⚙️ Actions"</strong> button at the top of the table.
                                            </div>
                                            <div class="bg-light p-3 rounded mb-2">
                                                <i class="fa fa-bolt text-danger me-2"/> <strong>Available Options in Actions Menu:</strong>
                                                <ul class="mt-2 mb-0 text-muted">
                                                    <li><strong>Mass Submit</strong> — Send all checked Draft KRS at once to Academic Advisor.</li>
                                                    <li><strong>Mass Approve</strong> — Approve all checked Submitted KRS at once (Advisor / Admin only).</li>
                                                    <li><strong>Mass Lock</strong> — Lock all checked Approved KRS and automatically generate KHS (Admin only).</li>
                                                    <li><strong>Mass Reject</strong> — Reject all checked Submitted KRS at once.</li>
                                                    <li><strong>Mass Unlock</strong> — Reopen locked KRS back to Approved status if corrections are needed (Admin only).</li>
                                                </ul>
                                            </div>
                                            <div class="bg-light p-3 rounded">
                                                <i class="fa fa-info-circle text-info me-2"/> <strong>Smart Note:</strong> The system automatically skips lines with mismatching status. For example, if you check 10 KRS and select <em>Mass Approve</em>, only KRS in Submitted status will be processed; Draft KRS will remain untouched.
                                            </div>
                                        </div>

                                        <!-- SECTION: PERAN & HAK AKSES -->
                                        <h4 class="fw-bold border-bottom pb-2 mb-4 mt-5">User Roles &amp; Permissions</h4>
                                        <p class="text-muted mb-4">This system is designed with a layered security hierarchy. Each user can only see and perform actions appropriate to their role.</p>

                                        <div class="table-responsive">
                                            <table class="table table-bordered table-hover align-middle">
                                                <thead class="table-dark">
                                                    <tr>
                                                        <th>Action</th>
                                                        <th class="text-center">Student (Portal)</th>
                                                        <th class="text-center">Academic Advisor</th>
                                                        <th class="text-center">Academic Admin</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr>
                                                        <td>Create &amp; Edit KRS (during open period)</td>
                                                        <td class="text-center text-success fw-bold">✓</td>
                                                        <td class="text-center text-muted">—</td>
                                                        <td class="text-center text-success fw-bold">✓ (anytime)</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Submit KRS</td>
                                                        <td class="text-center text-success fw-bold">✓</td>
                                                        <td class="text-center text-muted">—</td>
                                                        <td class="text-center text-success fw-bold">✓</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Approve / Reject KRS</td>
                                                        <td class="text-center text-danger">✗</td>
                                                        <td class="text-center text-success fw-bold">✓ (only their advised students)</td>
                                                        <td class="text-center text-success fw-bold">✓ (all)</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Lock KRS &amp; Generate KHS</td>
                                                        <td class="text-center text-danger">✗</td>
                                                        <td class="text-center text-danger">✗</td>
                                                        <td class="text-center text-success fw-bold">✓</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Input Grades (KHS)</td>
                                                        <td class="text-center text-danger">✗</td>
                                                        <td class="text-center text-success fw-bold">✓</td>
                                                        <td class="text-center text-success fw-bold">✓</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Manage Master Data (Programs, Rooms, etc)</td>
                                                        <td class="text-center text-danger">✗</td>
                                                        <td class="text-center text-danger">✗</td>
                                                        <td class="text-center text-success fw-bold">✓</td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>

                                        <!-- SECTION: PERIODE KRS -->
                                        <h4 class="fw-bold border-bottom pb-2 mb-4 mt-5">KRS Period Configuration</h4>
                                        <p class="text-muted mb-3">The system supports limiting KRS entry time so students can only fill during the specified period.</p>
                                        <div class="bg-light p-3 rounded mb-2">
                                            <i class="fa fa-calendar-check-o text-primary me-2"/> <strong>Setup Guide:</strong> Open <strong>Configuration → Academic Years</strong> menu → Choose active Academic Year → Fill <strong>KRS Start Date</strong> and <strong>KRS End Date</strong> fields.
                                        </div>
                                        <div class="bg-light p-3 rounded">
                                            <i class="fa fa-info-circle text-info me-2"/> <strong>Note:</strong> This period restriction <strong>only applies to Students</strong> (Portal users). Academic Admin can create or edit KRS anytime without being bound by the period, assisting students who cannot fill it themselves.
                                        </div>
                                    </section>
                                </div>
                                
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

</odoo>
