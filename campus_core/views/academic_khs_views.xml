<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_academic_khs_tree" model="ir.ui.view">
        <field name="name">academic.khs.tree</field>
        <field name="model">academic.khs</field>
        <field name="arch" type="xml">
            <list string="Student Transcripts (KHS)">
                <field name="name"/>
                <field name="student_id"/>
                <field name="academic_year_id"/>
                <field name="semester"/>
                <field name="total_credits"/>
                <field name="term_gpa" string="Term GPA"/>
                <field name="company_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_academic_khs_form" model="ir.ui.view">
        <field name="name">academic.khs.form</field>
        <field name="model">academic.khs</field>
        <field name="arch" type="xml">
            <form string="Student Transcript (KHS)">
                <header>
                    <button name="%(campus_core.action_report_khs)d" string="Print KHS" type="action" icon="fa-print" class="btn-secondary"/>
                    <button name="%(campus_core.action_report_transcript)d" string="Print Transkrip" type="action" icon="fa-print" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="academic_year_id"/>
                        </group>
                        <group>
                            <field name="semester" readonly="1" force_save="1"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="GPA Summary">
                        <group>
                            <field name="total_credits" readonly="1"/>
                            <field name="total_grade_points" readonly="1"/>
                        </group>
                        <group>
                            <field name="term_gpa" readonly="1" class="fw-bold"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Grades">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="subject_id" readonly="1" force_save="1"/>
                                    <field name="credits" readonly="1"/>
                                    <field name="numeric_grade"/>
                                    <field name="letter_grade" readonly="1"/>
                                    <field name="grade_points" readonly="1"/>
                                    <field name="schedule_ids" widget="many2many_tags" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- KHS Search -->
    <record id="view_academic_khs_search" model="ir.ui.view">
        <field name="name">academic.khs.search</field>
        <field name="model">academic.khs</field>
        <field name="arch" type="xml">
            <search string="Search KHS">
                <field name="name"/>
                <field name="student_id"/>
                <field name="academic_year_id"/>
                <separator/>
                <group name="group_by">
                    <filter string="Student" name="group_student" context="{'group_by': 'student_id'}"/>
                    <filter string="Academic Year" name="group_year" context="{'group_by': 'academic_year_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_academic_khs" model="ir.actions.act_window">
        <field name="name">Student KHS</field>
        <field name="res_model">academic.khs</field>
        <field name="view_mode">list,form,activity</field>
        <field name="search_view_id" ref="view_academic_khs_search"/>
    </record>
</odoo>
