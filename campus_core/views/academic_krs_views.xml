<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Standalone KRS Line Tree (Used for popups) -->
    <record id="view_academic_krs_line_tree_standalone" model="ir.ui.view">
        <field name="name">academic.krs.line.tree.standalone</field>
        <field name="model">academic.krs.line</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="student_id"/>
                <field name="krs_id"/>
                <field name="state" widget="badge" decoration-success="state == 'approved'" decoration-info="state == 'submitted'" decoration-muted="state == 'draft'" decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- KRS Kanban -->
    <record id="view_academic_krs_kanban" model="ir.ui.view">
        <field name="name">academic.krs.kanban</field>
        <field name="model">academic.krs</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_mobile">
                <field name="name"/>
                <field name="student_id"/>
                <field name="academic_year_id"/>
                <field name="state"/>
                <field name="total_credits"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <ul>
                                    <li>Student: <field name="student_id"/></li>
                                    <li>Term: <field name="academic_year_id"/></li>
                                    <li>Credits: <field name="total_credits"/></li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- KRS Tree -->
    <record id="view_academic_krs_tree" model="ir.ui.view">
        <field name="name">academic.krs.tree</field>
        <field name="model">academic.krs</field>
        <field name="arch" type="xml">
            <list string="Study Plan (KRS)" decoration-info="state == 'submitted'" decoration-success="state in ('approved', 'locked')" decoration-warning="state == 'revision'" decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="student_id"/>
                <field name="program_id"/>
                <field name="academic_year_id"/>
                <field name="advisor_id"/>
                <field name="total_credits"/>
                <field name="state" widget="badge" decoration-info="state == 'submitted'" decoration-success="state in ('approved', 'locked')" decoration-warning="state == 'revision'" decoration-danger="state == 'rejected'"/>
                <field name="company_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- KRS Form -->
    <record id="view_academic_krs_form" model="ir.ui.view">
        <field name="name">academic.krs.form</field>
        <field name="model">academic.krs</field>
        <field name="arch" type="xml">
            <form string="Study Plan (KRS)">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state not in ('draft', 'revision')"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'submitted'" groups="campus_core.group_campus_lecturer,campus_core.group_campus_administrator"/>
                    <button name="action_request_revision" string="Request Revision" type="object" invisible="state != 'submitted'" groups="campus_core.group_campus_lecturer,campus_core.group_campus_administrator"/>
                    <button name="action_reject" string="Reject" type="object" invisible="state != 'submitted'" groups="campus_core.group_campus_lecturer,campus_core.group_campus_administrator"/>
                    <button name="action_lock" string="Lock &amp; Generate KHS" type="object" class="oe_highlight" invisible="state != 'approved'" groups="campus_core.group_campus_administrator"/>
                    <button name="action_set_draft" string="Set to Draft" type="object" invisible="state not in ('approved', 'rejected', 'revision')" groups="campus_core.group_campus_administrator"/>
                    <button name="%(campus_core.action_report_krs)d" string="Print KRS" type="action" icon="fa-print" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,locked" options="{'clickable': True}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Student Information">
                            <field name="faculty_id" readonly="state not in ('draft', 'revision')" options="{'no_create': True}"/>
                            <field name="program_id" readonly="state not in ('draft', 'revision')" options="{'no_create': True}" domain="[('faculty_id', '=?', faculty_id)]"/>

                            <field name="student_id" readonly="state not in ('draft', 'revision')" options="{'no_create': True}" domain="[('is_student', '=', True), ('program_id', '=?', program_id), ('program_id.faculty_id', '=?', faculty_id)]"/>
                            <field name="advisor_id"/>
                        </group>
                        <group string="Academic Period">
                            <field name="academic_year_id" readonly="state not in ('draft', 'revision')"/>

                            <field name="package_id" readonly="state not in ('draft', 'revision')"/>
                            <field name="total_credits"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="KRS Lines">
                            <field name="line_ids" readonly="state not in ('draft', 'revision')">
                                <list editable="bottom">
                                    <field name="subject_id" options="{'no_create': True}" domain="[('program_id', '=', parent.program_id)]"/>
                                    <field name="schedule_id" domain="[('class_id.subject_id', '=', subject_id)]" options="{'no_create': True}"/>
                                    <field name="class_id" column_invisible="1"/>
                                    <field name="credits"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- KRS Search -->
    <record id="view_academic_krs_search" model="ir.ui.view">
        <field name="name">academic.krs.search</field>
        <field name="model">academic.krs</field>
        <field name="arch" type="xml">
            <search string="Search KRS">
                <field name="name"/>
                <field name="student_id"/>
                <field name="academic_year_id"/>
                <separator/>
                <filter string="Draft" name="filter_draft" domain="[('state','=','draft')]"/>
                <filter string="Waiting for Approval" name="filter_submitted" domain="[('state','=','submitted')]"/>
                <filter string="Approved" name="filter_approved" domain="[('state','=','approved')]"/>
                <filter string="Needs Revision" name="filter_revision" domain="[('state','=','revision')]"/>
                <filter string="Locked" name="filter_locked" domain="[('state','=','locked')]"/>
                <separator/>
                <group name="group_by">
                    <filter string="Student" name="group_student" context="{'group_by': 'student_id'}"/>
                    <filter string="Academic Year" name="group_year" context="{'group_by': 'academic_year_id'}"/>
                    <filter string="Program" name="group_program" context="{'group_by': 'program_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- KRS Action -->
    <record id="action_academic_krs" model="ir.actions.act_window">
        <field name="name">Study Plan (KRS)</field>
        <field name="res_model">academic.krs</field>
        <field name="view_mode">list,kanban,form,activity</field>
        <field name="search_view_id" ref="view_academic_krs_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Study Plan (KRS)
            </p>
            <p>Manage student course registrations per academic period.</p>
        </field>
    </record>

    <!-- Mass Action: Submit -->
    <record id="action_krs_mass_submit" model="ir.actions.server">
        <field name="name">Mass Submit</field>
        <field name="model_id" ref="model_academic_krs"/>
        <field name="binding_model_id" ref="model_academic_krs"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            for rec in records:
                if rec.state == 'draft':
                    rec.action_submit()
        </field>
    </record>

    <!-- Mass Action: Approve -->
    <record id="action_krs_mass_approve" model="ir.actions.server">
        <field name="name">Mass Approve</field>
        <field name="model_id" ref="model_academic_krs"/>
        <field name="binding_model_id" ref="model_academic_krs"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            for rec in records:
                if rec.state == 'submitted':
                    rec.action_approve()
        </field>
    </record>

    <!-- Mass Action: Lock -->
    <record id="action_krs_mass_lock" model="ir.actions.server">
        <field name="name">Mass Lock</field>
        <field name="model_id" ref="model_academic_krs"/>
        <field name="binding_model_id" ref="model_academic_krs"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            for rec in records:
                if rec.state == 'approved':
                    rec.action_lock()
        </field>
    </record>

    <!-- Mass Action: Reject -->
    <record id="action_krs_mass_reject" model="ir.actions.server">
        <field name="name">Mass Reject</field>
        <field name="model_id" ref="model_academic_krs"/>
        <field name="binding_model_id" ref="model_academic_krs"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            for rec in records:
                if rec.state == 'submitted':
                    rec.action_reject()
        </field>
    </record>

    <!-- Mass Action: Unlock -->
    <record id="action_krs_mass_unlock" model="ir.actions.server">
        <field name="name">Mass Unlock</field>
        <field name="model_id" ref="model_academic_krs"/>
        <field name="binding_model_id" ref="model_academic_krs"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            for rec in records:
                if rec.state == 'locked':
                    rec.action_unlock()
        </field>
    </record>

</odoo>
