<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Replace Default Layout elements (Copyright and Head Scripts) -->
    <template id="campus_website_layout" inherit_id="website.layout" name="Campus Website Layout">
        <!-- Replace Default Copyright Bar -->
        <xpath expr="//div[hasclass('o_footer_copyright')]" position="replace">
            <div class="o_footer_copyright o_colored_level o_cc bg-dark text-white border-top border-secondary">
                <div class="container py-3">
                    <div class="row align-items-center">
                        <div class="col-md-12 text-center">
                            <p class="mb-0 text-light">
                                © 2026 Copyright: <strong>Campus Academic by Hajril Malik</strong>. All Rights Reserved.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>

        <!-- Dynamic Header Adjustments -->
        <xpath expr="//head" position="inside">
            <style type="text/css">
                /* Remove Your Logo from Header */
                header .navbar-brand {
                    display: none !important;
                }
                /* Remove Contact Us menu/button from Header */
                header a[href*="/contactus"] {
                    display: none !important;
                }
            </style>
            <script type="text/javascript">
                document.addEventListener("DOMContentLoaded", function() {
                    const phoneLinks = document.querySelectorAll('header a[href^="tel:"]');
                    phoneLinks.forEach(link => {
                        link.href = "https://wa.me/6281178783903";
                        link.target = "_blank";
                        link.classList.add("text-success", "fw-bold");
                        link.innerHTML = '<i class="fa fa-whatsapp text-success me-1"></i><span>081178783903</span>';
                    });

                    // Hide PMB Admission menu if user is logged in
                    // Check special element in header that only appears when logged in
                    const isLoggedIn = document.querySelector('header a[href*="/web/session/logout"]') || 
                                     document.querySelector('header .o_user_menu') || 
                                     document.querySelector('header a[href="/my/home"]');
                    if (isLoggedIn) {
                        const pmbMenu = document.querySelector('header a[href*="/admission"]');
                        if (pmbMenu) {
                            if (pmbMenu.parentElement) {
                                pmbMenu.parentElement.style.display = 'none';
                            }
                        }
                    }
                });
            </script>
        </xpath>
    </template>

    <!-- Replace Default Custom Footer -->
    <template id="campus_website_layout_footer" inherit_id="website.footer_custom" name="Campus Website Layout Footer">
        <!-- Replace Default Footer with Custom Author Footer -->
        <xpath expr="//div[@id='footer']" position="replace">
            <div id="footer" class="bg-dark text-white pt-5 pb-4 border-top border-4 border-primary">
                <div class="container text-center text-md-start">
                    <div class="row text-center text-md-start">
                        <!-- About -->
                        <div class="col-md-5 col-lg-5 col-xl-5 mx-auto mt-3">
                            <h5 class="text-uppercase mb-4 fw-bold text-white">Campus Academic SIAKAD</h5>
                            <p class="text-light">
                                Integrated Academic Information System built using modern Odoo technology.
                                Supports full management of New Student Admissions, Academic Portal, and Employee Management.
                            </p>
                        </div>

                        <!-- Developer Info -->
                        <div class="col-md-5 col-lg-5 col-xl-5 mx-auto mt-3">
                            <h5 class="text-uppercase mb-4 fw-bold text-white">Developed By</h5>
                            <p>
                                <i class="fa fa-user me-3 text-primary"></i> <strong>Hajril Malik</strong>
                            </p>
                            <p>
                                <a href="mailto:hajrilmalik82@gmail.com" class="text-light text-decoration-none">
                                    <i class="fa fa-envelope me-3 text-warning"></i> hajrilmalik82@gmail.com
                                </a>
                            </p>
                            <p>
                                <a href="https://wa.me/6281178783903" class="text-light text-decoration-none" target="_blank">
                                    <i class="fa fa-whatsapp me-3 text-success"></i> 081178783903
                                </a>
                            </p>
                            <p>
                                <a href="https://www.linkedin.com/in/hajrilmalik/" class="text-light text-decoration-none" target="_blank">
                                    <i class="fa fa-linkedin me-3 text-info"></i> LinkedIn Profile
                                </a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- Demo Login for Portfolio -->
    <template id="campus_demo_login" inherit_id="web.login" name="Campus Demo Login">
        <xpath expr="//form" position="after">
            <div class="mt-4 pt-3 border-top text-center">
                <h6 class="text-muted mb-2"><i class="fa fa-info-circle me-1"></i> Portfolio Reviewer?</h6>
                <p class="small text-muted mb-3">Use these demo credentials to explore the system</p>
                <div class="bg-light p-2 rounded mb-3 text-start small border">
                    <div><strong>Email:</strong> admincampus@gmail.com</div>
                    <div><strong>Password:</strong> 123</div>
                </div>
                <button type="button" class="btn btn-primary w-100 fw-bold" onclick="document.getElementById('login').value='admincampus@gmail.com'; document.getElementById('password').value='123'; document.querySelector('form.oe_login_form').submit();">
                    <i class="fa fa-rocket me-2"></i> Auto-Login as Admin
                </button>
            </div>
        </xpath>
    </template>
</odoo>
