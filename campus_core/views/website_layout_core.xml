<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Replace Default Layout elements (Copyright and Head Scripts) -->
    <template id="campus_website_layout" inherit_id="website.layout" name="Campus Website Layout">
        <!-- Replace Default Copyright Bar -->
        <xpath expr="//div[hasclass('o_footer_copyright')]" position="replace">
            <div class="o_footer_copyright o_colored_level o_cc bg-dark text-white border-top border-secondary">
                <div class="container py-3">
                    <div class="row align-items-center">
                        <div class="col-md-12 text-center">
                            <p class="mb-0 text-light">
                                © 2026 Copyright: <strong>Campus Academic by Hajril Malik</strong>. All Rights Reserved.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>

        <!-- Dynamic Header Adjustments -->
        <xpath expr="//head" position="inside">
            <style type="text/css">
                /* Remove Your Logo from Header */
                header .navbar-brand {
                    display: none !important;
                }
                /* Remove Contact Us menu/button from Header */
                header a[href*="/contactus"] {
                    display: none !important;
                }
            </style>
            <script type="text/javascript">
                document.addEventListener("DOMContentLoaded", function() {
                    const phoneLinks = document.querySelectorAll('header a[href^="tel:"]');
                    phoneLinks.forEach(link => {
                        link.href = "https://wa.me/6281178783903";
                        link.target = "_blank";
                        link.classList.add("text-success", "fw-bold");
                        link.innerHTML = '<i class="fa fa-whatsapp text-success me-1"></i><span>081178783903</span>';
                    });

                    // Hide PMB Admission menu if user is logged in
                    // Check special element in header that only appears when logged in
                    const isLoggedIn = document.querySelector('header a[href*="/web/session/logout"]') || 
                                     document.querySelector('header .o_user_menu') || 
                                     document.querySelector('header a[href="/my/home"]');
                    if (isLoggedIn) {
                        if (pmbMenu) {
                            if (pmbMenu.parentElement) {
                                pmbMenu.parentElement.style.display = 'none';
                            }
                        }
                    }
                });
            </script>
        </xpath>
    </template>

    <!-- Replace Default Custom Footer -->
    <template id="campus_website_layout_footer" inherit_id="website.footer_custom" name="Campus Website Layout Footer">
        <!-- Replace Default Footer with Custom Author Footer -->
        <xpath expr="//div[@id='footer']" position="replace">
            <div id="footer" class="bg-dark text-white pt-5 pb-4 border-top border-4 border-primary">
                <div class="container text-center text-md-start">
                    <div class="row text-center text-md-start">
                        <!-- About -->
                        <div class="col-md-5 col-lg-5 col-xl-5 mx-auto mt-3">
                            <h5 class="text-uppercase mb-4 fw-bold text-white">Campus Academic SIAKAD</h5>
                            <p class="text-light">
                                Integrated Academic Information System built using modern Odoo technology.
                                Supports full management of New Student Admissions, Academic Portal, and Employee Management.
                            </p>
                        </div>

                        <!-- Developer Info -->
                        <div class="col-md-5 col-lg-5 col-xl-5 mx-auto mt-3">
                            <h5 class="text-uppercase mb-4 fw-bold text-white">Developed By</h5>
                            <p>
                                <i class="fa fa-user me-3 text-primary"></i> <strong>Hajril Malik</strong>
                            </p>
                            <p>
                                <a href="mailto:hajrilmalik82@gmail.com" class="text-light text-decoration-none">
                                    <i class="fa fa-envelope me-3 text-warning"></i> hajrilmalik82@gmail.com
                                </a>
                            </p>
                            <p>
                                <a href="https://wa.me/6281178783903" class="text-light text-decoration-none" target="_blank">
                                    <i class="fa fa-whatsapp me-3 text-success"></i> 081178783903
                                </a>
                            </p>
                            <p>
                                <a href="https://www.linkedin.com/in/hajrilmalik/" class="text-light text-decoration-none" target="_blank">
                                    <i class="fa fa-linkedin me-3 text-info"></i> LinkedIn Profile
                                </a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- Demo Login for Portfolio -->
    <template id="campus_demo_login" inherit_id="web.login" name="Campus Demo Login">
        <xpath expr="//form" position="before">
            <style>
                .portfolio-demo-box {
                    display: none;
                }
                @media (min-width: 992px) {
                    .portfolio-demo-box {
                        display: flex;
                        flex-direction: column;
                        justify-content: center;
                        position: fixed;
                        top: 0;
                        left: 0;
                        height: 100vh;
                        width: 350px;
                        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
                        color: white;
                        z-index: 1000;
                        padding: 30px;
                        box-shadow: 5px 0 15px rgba(0,0,0,0.2);
                    }
                    /* Ensure the main container shifts so it is not hidden */
                    body {
                        padding-left: 350px;
                    }
                }
            </style>
            
            <!-- Desktop side panel -->
            <div class="portfolio-demo-box">
                <div class="text-center mb-4">
                    <i class="fa fa-university fa-4x text-light mb-3"></i>
                    <h4 class="fw-bold text-white mb-0">Campus Academic</h4>
                    <p class="text-light opacity-75">SIAKAD Portfolio</p>
                </div>
                
                <h6 class="text-warning mb-3 fw-bold border-bottom border-warning pb-2">
                    <i class="fa fa-info-circle me-2"></i> Portfolio Reviewer?
                </h6>
                <p class="small text-light mb-4">
                    Use these demo credentials to explore all features in the system based on roles.
                </p>
                
                <!-- Campus Admin -->
                <div class="bg-white bg-opacity-10 p-2 rounded mb-2 border border-light border-opacity-25 shadow-sm">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <small class="text-warning fw-bold d-block">Campus Admin</small>
                            <small class="d-block text-light">admincampus@gmail.com</small>
                        </div>
                        <button type="button" class="btn btn-sm btn-warning fw-bold text-dark" onclick="document.getElementById('login').value='admincampus@gmail.com'; document.getElementById('password').value='123'; document.querySelector('form.oe_login_form').submit();">
                            <i class="fa fa-sign-in"></i> Login
                        </button>
                    </div>
                </div>

                <!-- PMB Admin -->
                <div class="bg-white bg-opacity-10 p-2 rounded mb-2 border border-light border-opacity-25 shadow-sm">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <small class="text-info fw-bold d-block">PMB Admin</small>
                            <small class="d-block text-light">pmbadmin@gmail.com</small>
                        </div>
                        <button type="button" class="btn btn-sm btn-info fw-bold text-white" onclick="document.getElementById('login').value='pmbadmin@gmail.com'; document.getElementById('password').value='123'; document.querySelector('form.oe_login_form').submit();">
                            <i class="fa fa-sign-in"></i> Login
                        </button>
                    </div>
                </div>

                <!-- TU Admin -->
                <div class="bg-white bg-opacity-10 p-2 rounded mb-2 border border-light border-opacity-25 shadow-sm">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <small class="text-success fw-bold d-block">TU Admin</small>
                            <small class="d-block text-light">tuadmin@gmail.com</small>
                        </div>
                        <button type="button" class="btn btn-sm btn-success fw-bold text-white" onclick="document.getElementById('login').value='tuadmin@gmail.com'; document.getElementById('password').value='123'; document.querySelector('form.oe_login_form').submit();">
                            <i class="fa fa-sign-in"></i> Login
                        </button>
                    </div>
                </div>
                
                <div class="text-center mt-3">
                    <small class="text-light opacity-75">Password for all: <strong>123</strong></small>
                </div>
            </div>
            
            <!-- Mobile minimal version -->
            <div class="d-block d-lg-none mt-3 mb-4 text-center border p-3 rounded bg-light">
                <h6 class="text-muted fw-bold"><i class="fa fa-info-circle me-1"></i> Demo Login (Pass: 123)</h6>
                <button type="button" class="btn btn-warning w-100 fw-bold mt-2" onclick="document.getElementById('login').value='admincampus@gmail.com'; document.getElementById('password').value='123'; document.querySelector('form.oe_login_form').submit();">
                    Campus Admin
                </button>
                <button type="button" class="btn btn-info w-100 fw-bold mt-2 text-white" onclick="document.getElementById('login').value='pmbadmin@gmail.com'; document.getElementById('password').value='123'; document.querySelector('form.oe_login_form').submit();">
                    PMB Admin
                </button>
                <button type="button" class="btn btn-success w-100 fw-bold mt-2 text-white" onclick="document.getElementById('login').value='tuadmin@gmail.com'; document.getElementById('password').value='123'; document.querySelector('form.oe_login_form').submit();">
                    TU Admin
                </button>
            </div>
        </xpath>
    </template>
</odoo>
