<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Class Views -->
    <record id="view_academic_class_tree" model="ir.ui.view">
        <field name="name">academic.class.tree</field>
        <field name="model">academic.class</field>
        <field name="arch" type="xml">
            <list string="Classes">
                <field name="name"/>
                <field name="subject_id"/>
                <field name="academic_year_id"/>
                <field name="start_date"/>
                <field name="class_capacity_display"/>
                <field name="company_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_academic_class_form" model="ir.ui.view">
        <field name="name">academic.class.form</field>
        <field name="model">academic.class</field>
        <field name="arch" type="xml">
            <form string="Class">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Class Name (e.g. ALPRO - A)"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="subject_id"/>
                            <field name="academic_year_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Weekly Schedule">
                            <group>
                                <field name="class_capacity_display" readonly="1" class="fw-bold"/>
                            </group>
                            <field name="schedule_ids">
                                <list editable="bottom">
                                    <field name="class_code"/>
                                    <field name="day_of_week"/>
                                    <field name="start_time" widget="float_time"/>
                                    <field name="end_time" widget="float_time"/>
                                    <field name="room_id"/>
                                    <field name="capacity_display"/>
                                    <field name="lecturer_id"/>
                                    <field name="company_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Students">
                            <field name="student_line_ids">
                                <list editable="bottom">
                                    <field name="class_id" column_invisible="1"/>
                                    <field name="student_id"/>
                                    <field name="schedule_ids" widget="many2many_tags"/>
                                </list>
                            </field>
                        </page>
                        <page string="Real Sessions">
                            <div class="mb-2">
                                <button name="action_generate_sessions" string="Generate Sessions" type="object" class="oe_highlight"/>
                            </div>
                            <field name="session_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="start_datetime"/>
                                    <field name="end_datetime"/>
                                    <field name="room_id"/>
                                    <field name="lecturer_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Session Views -->
    <record id="view_academic_class_session_tree" model="ir.ui.view">
        <field name="name">academic.class.session.tree</field>
        <field name="model">academic.class.session</field>
        <field name="arch" type="xml">
            <list string="Sessions">
                <field name="name"/>
                <field name="class_id"/>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="room_id"/>
                <field name="lecturer_id"/>
            </list>
        </field>
    </record>

    <record id="view_academic_class_session_form" model="ir.ui.view">
        <field name="name">academic.class.session.form</field>
        <field name="model">academic.class.session</field>
        <field name="arch" type="xml">
            <form string="Session">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="class_id"/>
                        </group>
                        <group>
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                            <field name="room_id"/>
                            <field name="lecturer_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Calendar view for Session -->
    <record id="view_academic_class_session_calendar" model="ir.ui.view">
        <field name="name">academic.class.session.calendar</field>
        <field name="model">academic.class.session</field>
        <field name="arch" type="xml">
            <calendar string="Class Sessions" date_start="start_datetime" date_stop="end_datetime" color="class_id">
                <field name="name"/>
                <field name="room_id"/>
                <field name="lecturer_id"/>
            </calendar>
        </field>
    </record>
</odoo>
