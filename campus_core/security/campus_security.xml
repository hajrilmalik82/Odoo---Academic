<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Module Category -->
        <record id="module_category_campus" model="ir.module.category">
            <field name="name">Campus Academic</field>
            <field name="description">Helps you manage your Campus Master Data, Curriculums, and KRS.</field>
            <field name="sequence">10</field>
        </record>

        <record id="privilege_campus_academic" model="res.groups.privilege">
            <field name="name">Role</field>
            <field name="category_id" ref="module_category_campus"/>
        </record>

        <!-- Groups -->
        <record id="group_campus_lecturer" model="res.groups">
            <field name="name">Lecturer</field>
            <field name="privilege_id" ref="privilege_campus_academic"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_campus_administrator" model="res.groups">
            <field name="name">Administrator</field>
            <field name="privilege_id" ref="privilege_campus_academic"/>
            <field name="implied_ids" eval="[(4, ref('group_campus_lecturer'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="rule_student_own_krs" model="ir.rule">
            <field name="name">Student can only see own KRS</field>
            <field name="model_id" ref="model_academic_krs"/>
            <field name="domain_force">[('student_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_student_own_krs_line" model="ir.rule">
            <field name="name">Student can only see own KRS Lines</field>
            <field name="model_id" ref="model_academic_krs_line"/>
            <field name="domain_force">[('krs_id.student_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <record id="rule_student_own_khs" model="ir.rule">
            <field name="name">Student can only see own KHS</field>
            <field name="model_id" ref="model_academic_khs"/>
            <field name="domain_force">[('student_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>
    </data>
</odoo>
