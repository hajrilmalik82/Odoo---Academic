<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Academic KRS -->
        <record id="seq_academic_krs" model="ir.sequence">
            <field name="name">Academic KRS</field>
            <field name="code">academic.krs</field>
            <field name="prefix">KRS/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Academic KHS -->
        <record id="seq_academic_khs" model="ir.sequence">
            <field name="name">Academic KHS</field>
            <field name="code">academic.khs</field>
            <field name="prefix">KHS/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
