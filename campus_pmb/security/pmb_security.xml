<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Module Category -->
        <record id="module_category_campus_pmb" model="ir.module.category">
            <field name="name">Campus Admissions (PMB)</field>
            <field name="description">Helps you manage the student admissions and candidates pipeline.</field>
            <field name="sequence">11</field>
        </record>

        <record id="privilege_campus_pmb" model="res.groups.privilege">
            <field name="name">Role</field>
            <field name="category_id" ref="module_category_campus_pmb"/>
        </record>

        <record id="group_pmb_officer" model="res.groups">
            <field name="name">Admissions Officer</field>
            <field name="privilege_id" ref="privilege_campus_pmb"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_pmb_manager" model="res.groups">
            <field name="name">Admissions Manager</field>
            <field name="privilege_id" ref="privilege_campus_pmb"/>
            <field name="implied_ids" eval="[(4, ref('group_pmb_officer'))]"/>
        </record>
    </data>

    <data noupdate="1">
        <!-- Record Rule for PMB Officers (Filtered Access) -->
        <record id="rule_pmb_officer_admission_access" model="ir.rule">
            <field name="name">PMB Officer: Faculty and Program Access</field>
            <field name="model_id" ref="model_campus_admission"/>
            <field name="domain_force">
                ['|', '|', 
                 ('program_id', 'in', user.employee_id.pmb_program_ids.ids), 
                 ('program_id.faculty_id', 'in', user.employee_id.pmb_faculty_ids.ids), 
                 (1, '=', 1 if not user.employee_id.pmb_program_ids and not user.employee_id.pmb_faculty_ids else 0)]
            </field>
            <field name="groups" eval="[(4, ref('campus_pmb.group_pmb_officer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record Rule for Administrators (All Access) -->
        <record id="rule_admin_admission_access" model="ir.rule">
            <field name="name">Campus Admin: All Admissions Access</field>
            <field name="model_id" ref="model_campus_admission"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('campus_core.group_campus_administrator'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
