<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="group_pmb" model="res.groups">
            <field name="name">PMB Staff</field>
            <field name="privilege_id" ref="campus_core.privilege_campus_academic"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="campus_core.group_campus_administrator" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('campus_pmb.group_pmb'))]"/>
        </record>

    </data>

    <data noupdate="1">
        <!-- Record Rule for PMB Officers (Filtered Access) -->
        <record id="rule_pmb_admission_access" model="ir.rule">
            <field name="name">PMB: Faculty and Program Access</field>
            <field name="model_id" ref="model_campus_admission"/>
            <field name="domain_force">
                ['|', '|', '|',
                 (1, '=', 1 if user.employee_id.pmb_all_programs or user.employee_id.pmb_all_faculties else 0),
                 ('program_id', 'in', user.employee_id.pmb_program_ids.ids), 
                 ('program_id.faculty_id', 'in', user.employee_id.pmb_faculty_ids.ids), 
                 (1, '=', 1 if not user.employee_id.pmb_program_ids and not user.employee_id.pmb_faculty_ids and not user.employee_id.pmb_all_faculties and not user.employee_id.pmb_all_programs else 0)]
            </field>
            <field name="groups" eval="[(4, ref('campus_pmb.group_pmb'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record Rule for Administrators (All Access) -->
        <record id="rule_admin_admission_access" model="ir.rule">
            <field name="name">Campus Admin: All Admissions Access</field>
            <field name="model_id" ref="model_campus_admission"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('campus_core.group_campus_administrator'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
