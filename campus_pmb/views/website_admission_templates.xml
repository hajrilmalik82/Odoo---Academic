<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Admission Form Template -->
    <template id="admission_form" name="Admission Form">
        <t t-call="website.layout">
            <div id="wrap">
                <div class="container mt-5 mb-5">
                    <div class="row justify-content-center">
                        <div class="col-md-8">
                            <div class="card shadow-sm border-0">
                                <div class="card-header bg-primary text-white">
                                    <h3 class="mb-0">New Student Registration</h3>
                                </div>
                                <div class="card-body p-4">
                                    <t t-if="error">
                                        <div class="alert alert-danger" role="alert">
                                            <t t-esc="error"/>
                                        </div>
                                    </t>
                                    <p class="text-muted mb-4">Please fill out the form below with correct information.</p>
                                    
                                    <form action="/admission/submit" method="post" enctype="multipart/form-data">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        
                                        <div class="row mb-3">
                                            <div class="col-md-6">
                                                <label class="form-label" for="name">Full Name <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" name="name" required="required" placeholder="Example: John Doe"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label" for="email">Email Address <span class="text-danger">*</span></label>
                                                <input type="email" class="form-control" name="email" required="required" placeholder="Example: john@example.com"/>
                                            </div>
                                        </div>

                                        <div class="row mb-3">
                                            <div class="col-md-6">
                                                <label class="form-label" for="phone">Phone Number/WhatsApp <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" name="phone" required="required" placeholder="Example: 08123456789"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label" for="previous_school">Previous School</label>
                                                <input type="text" class="form-control" name="previous_school" placeholder="Example: High School 1"/>
                                            </div>
                                        </div>

                                        <div class="row mb-3">
                                            <div class="col-md-6">
                                                <label class="form-label" for="faculty_id">Faculty <span class="text-danger">*</span></label>
                                                <select class="form-select" name="faculty_id" id="faculty_id" required="required">
                                                    <option value="">-- Choose Faculty --</option>
                                                    <t t-foreach="faculties" t-as="fac">
                                                        <option t-att-value="fac.id"><t t-esc="fac.name"/></option>
                                                    </t>
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label" for="program_id">Study Program <span class="text-danger">*</span></label>
                                                <select class="form-select" name="program_id" id="program_id" required="required" disabled="disabled">
                                                    <option value="">-- Choose Study Program --</option>
                                                    <t t-foreach="programs" t-as="prog">
                                                        <option t-att-value="prog.id" t-att-data-faculty="prog.faculty_id.id"><t t-esc="prog.name"/></option>
                                                    </t>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="mb-4">
                                            <label class="form-label" for="admission_path">Admission Path <span class="text-danger">*</span></label>
                                            <select class="form-select" name="admission_path" required="required">
                                                <option value="regular">Regular</option>
                                                <option value="scholarship">Scholarship</option>
                                                <option value="transfer">Transfer</option>
                                            </select>
                                        </div>

                                        <div class="d-grid">
                                            <button type="submit" class="btn btn-primary btn-lg">Submit Application</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <script type="text/javascript">
                document.addEventListener('DOMContentLoaded', function() {
                    var facultySelect = document.getElementById('faculty_id');
                    var programSelect = document.getElementById('program_id');
                    if(facultySelect &amp;&amp; programSelect) {
                        var allPrograms = Array.from(programSelect.options).slice(1);
                        
                        facultySelect.addEventListener('change', function() {
                            var selectedFaculty = this.value;
                            
                            programSelect.innerHTML = '&lt;option value=""&gt;-- Choose Study Program --&lt;/option&gt;';
                            
                            if (selectedFaculty) {
                                programSelect.removeAttribute('disabled');
                                allPrograms.forEach(function(opt) {
                                    if (opt.getAttribute('data-faculty') === selectedFaculty) {
                                        programSelect.appendChild(opt.cloneNode(true));
                                    }
                                });
                            } else {
                                programSelect.setAttribute('disabled', 'disabled');
                            }
                        });
                    }
                });
            </script>
        </t>
    </template>

    <!-- Admission Thanks Template -->
    <template id="admission_thanks" name="Admission Thanks">
        <t t-call="website.layout">
            <div id="wrap">
                <div class="container mt-5 mb-5 text-center">
                    <div class="row justify-content-center">
                        <div class="col-md-6">
                            <div class="card shadow-sm border-0 py-5">
                                <div class="card-body">
                                    <h1 class="text-success mb-4"><i class="fa fa-check-circle fa-2x"></i></h1>
                                    <h2 class="mb-3">Application Successful!</h2>
                                    <p class="text-muted lead">Thank you, your application has been received.</p>
                                    <p class="text-muted">Our admissions team will process your data shortly and contact you via Email or Phone for the next steps.</p>
                                    <a href="/" class="btn btn-primary mt-4">Back to Homepage</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Website Menu Item -->
    <record id="menu_admission" model="website.menu">
        <field name="name">PMB Admission</field>
        <field name="url">/admission</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence" type="int">20</field>
    </record>

</odoo>
