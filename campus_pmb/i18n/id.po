#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-check-circle text-success me-2\"/> <strong>Action:</strong>"
" Committee clicks <strong>Accept</strong>. The status changes to "
"<em>Accepted</em>."
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-check-circle text-success me-2\"/> <strong>Action:</strong>"
" Committee clicks <strong>Submit</strong> from the <em>Actions</em> menu "
"(Gear Icon) or form view."
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-check-circle text-success me-2\"/> <strong>Action:</strong>"
" If all documents are complete, the committee clicks <strong>Verify "
"Documents</strong>."
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-check-circle text-success me-2\"/> <strong>Action:</strong>"
" The committee clicks <strong>Verify Payment</strong> to validate the "
"payment."
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-check-circle text-success me-2\"/> Next, the committee "
"continues the review process from within the Odoo backend following the "
"workflow stages above."
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-cogs text-success me-2\"/>Document Automation &amp; "
"Validation"
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-exclamation-triangle text-danger me-2\"/> "
"<strong>Restrictions:</strong> Candidates who are already in "
"<em>Accepted</em> or <em>Registered</em> status <strong>cannot</strong> be "
"rejected anymore to prevent accidental cancellation after account creation."
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-exclamation-triangle text-danger me-2\"/> <strong>Strict "
"Validation:</strong> If the \"Payment Reference\" column is empty, the "
"system blocks candidate acceptance and displays a warning alert."
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-exclamation-triangle text-danger me-2\"/> <strong>Strict "
"Validation:</strong> The committee <strong>cannot</strong> proceed to the "
"next stage if there are still mandatory documents that have not been "
"received (Checklist is not 100%)."
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-filter text-primary me-2\"/>Smart Navigation (Search Panel)"
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-globe text-primary me-2\"/> <strong>URL Access:</strong> "
"Prospective students simply open the page <strong>/admission/apply</strong> "
"on the campus website, fill out the online form, and click <strong>Submit "
"Application</strong>. The system automatically creates a new record in "
"Admissions with <em>Draft</em> status."
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid "<i class=\"fa fa-graduation-cap me-2\"/> PMB Admission Module"
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-id-card text-dark me-2\"/> <strong>Automatic Student ID "
"&amp; Academic Attributes:</strong> The system automatically creates the "
"Student Registration Number (NIM) based on Faculty, Study Program, and Year."
" It also sets the enrollment generation automatically."
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-magic text-dark me-2\"/> <strong>Access "
"Provisioning:</strong> Student accounts are instantly linked with Portal "
"access so they can log in to view schedules or fill out KRS."
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-magic text-dark me-2\"/> <strong>Contact Creation "
"(Res.Partner):</strong> Candidate data is automatically migrated into a "
"official Campus Contact database with Faculty and Study Program linked."
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-magic text-dark me-2\"/> <strong>Portal Account Creation "
"(Res.Users):</strong> Odoo automatically creates login accounts for students"
" with their Email as the username."
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-shield text-danger me-2\"/>Data Security (Row-Level "
"Security)"
msgstr ""

#. module: campus_pmb
#: model_terms:ir.ui.view,arch_db:campus_pmb.pmb_homepage_docs
msgid ""
"<i class=\"fa fa-times-circle text-danger me-2\"/> <strong>Action:</strong> "
"Committee clicks <strong>Reject</strong> from the form or <em>Actions</em> "
"menu. The status changes to <em>Rejected</em> and cannot be processed "
"further."
msgstr ""

