<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Activity Type: Document Review -->
        <record id="mail_activity_type_document_review" model="mail.activity.type">
            <field name="name">Review Admission Documents</field>
            <field name="summary">Review and verify the applicant's submitted documents</field>
            <field name="res_model">campus.admission</field>
            <field name="category">default</field>
            <field name="delay_count">5</field>
            <field name="delay_unit">days</field>
            <field name="icon">fa-file-text</field>
        </record>

        <!-- Activity Type: Payment Verification -->
        <record id="mail_activity_type_payment_verification" model="mail.activity.type">
            <field name="name">Verify Admission Payment</field>
            <field name="summary">Verify the applicant's payment for admission</field>
            <field name="res_model">campus.admission</field>
            <field name="category">default</field>
            <field name="delay_count">3</field>
            <field name="delay_unit">days</field>
            <field name="icon">fa-money</field>
        </record>

        <!-- Activity Type: Create Student Account -->
        <record id="mail_activity_type_create_account" model="mail.activity.type">
            <field name="name">Create Student Account</field>
            <field name="summary">Create portal user and student profile for accepted applicant</field>
            <field name="res_model">campus.admission</field>
            <field name="category">default</field>
            <field name="delay_count">2</field>
            <field name="delay_unit">days</field>
            <field name="icon">fa-user-plus</field>
        </record>

    </data>
</odoo>
