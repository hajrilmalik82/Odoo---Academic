<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_job_form_inherit_academic" model="ir.ui.view">
        <field name="name">hr.job.form.inherit.academic</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_hr_job_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="after">
                <group string="Academic Profile">
                    <field name="academic_role"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
