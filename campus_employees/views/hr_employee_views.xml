<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_academic" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.academic</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Lecturer Profile" invisible="not is_lecturer">
                    <group>
                        <field name="is_lecturer" invisible="1"/>
                        <field name="nidn"/>
                        <field name="academic_rank"/>
                        <field name="faculty_id"/>
                        <field name="program_id"/>
                    </group>
                </page>
                <page string="PMB Jurisdiction" invisible="not is_pmb_staff">
                    <group>
                        <field name="is_pmb_staff" invisible="1"/>
                        <field name="pmb_faculty_ids" widget="many2many_tags"/>
                        <field name="pmb_program_ids" widget="many2many_tags"/>
                    </group>
                </page>
            </xpath>
            <xpath expr="//field[@name='job_id']" position="attributes">
                <attribute name="context">{'filter_lecturer': context.get('default_is_lecturer', False), 'filter_pmb': context.get('default_is_pmb_staff', False)}</attribute>
            </xpath>
        </field>
    </record>

    <!-- Action for PMB Staff -->
    <record id="action_hr_employee_pmb_staff" model="ir.actions.act_window">
        <field name="name">PMB Staff</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_pmb_staff', '=', True)]</field>
        <field name="context">{'default_is_pmb_staff': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new PMB Staff
            </p>
        </field>
    </record>
</odoo>
