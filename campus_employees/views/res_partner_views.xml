<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_campus_employees" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.campus.employees</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="campus_core.view_partner_form_inherit_campus"/>
        <field name="arch" type="xml">
            <field name="academic_advisor_id" position="attributes">
                <attribute name="domain">[('academic_role', '=', 'lecturer'), ('program_id', '=', program_id)]</attribute>
            </field>
        </field>
    </record>
    
    <record id="view_campus_student_form_standalone_employees" model="ir.ui.view">
        <field name="name">res.partner.form.student.standalone.employees</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="campus_core.view_campus_student_form_standalone"/>
        <field name="arch" type="xml">
            <field name="academic_advisor_id" position="attributes">
                <attribute name="domain">[('academic_role', '=', 'lecturer'), ('program_id', '=', program_id)]</attribute>
            </field>
        </field>
    </record>
</odoo>
