<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Force noupdate=False for the rules so they can be updated on existing databases -->
        <function name="write" model="ir.model.data">
            <function name="search" model="ir.model.data">
                <value eval="[('module', '=', 'campus_employees'), ('name', 'in', ['rule_academic_staff_krs_access', 'rule_academic_staff_khs_access'])]"/>
            </function>
            <value eval="{'noupdate': False}"/>
        </function>

        <record id="rule_academic_staff_krs_access" model="ir.rule">
            <field name="name">Academic Staff: Faculty and Program Access for KRS</field>
            <field name="model_id" ref="campus_core.model_academic_krs"/>
            <field name="domain_force">
                [
                    '&amp;',
                    (1, '=', 1) if user.employee_id.academic_all_programs else ('program_id', 'in', user.employee_id.academic_program_ids.ids),
                    (1, '=', 1) if user.employee_id.academic_all_faculties else ('program_id.faculty_id', 'in', user.employee_id.academic_faculty_ids.ids)
                ]
            </field>
            <field name="groups" eval="[(4, ref('campus_core.group_campus_academic_staff'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_academic_staff_khs_access" model="ir.rule">
            <field name="name">Academic Staff: Faculty and Program Access for KHS</field>
            <field name="model_id" ref="campus_core.model_academic_khs"/>
            <field name="domain_force">
                [
                    '&amp;',
                    (1, '=', 1) if user.employee_id.academic_all_programs else ('student_id.program_id', 'in', user.employee_id.academic_program_ids.ids),
                    (1, '=', 1) if user.employee_id.academic_all_faculties else ('student_id.program_id.faculty_id', 'in', user.employee_id.academic_faculty_ids.ids)
                ]
            </field>
            <field name="groups" eval="[(4, ref('campus_core.group_campus_academic_staff'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
